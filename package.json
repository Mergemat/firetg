{
  "name": "firetg",
  "version": "0.2.5",
  "description": "Telegram MTProto CLI for scripts and agents, powered by mtcute.",
  "license": "MIT",
  "author": "Bagauddin Omarov",
  "keywords": [
    "telegram",
    "mtproto",
    "cli",
    "bun",
    "agents"
  ],
  "homepage": "https://github.com/Mergemat/firetg#readme",
  "bugs": {
    "url": "https://github.com/Mergemat/firetg/issues"
  },
  "module": "index.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mergemat/firetg.git"
  },
  "bin": {
    "firetg": "index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "bun run docs:build && vitepress preview docs",
    "release": "bun test && bun run typecheck && bun scripts/release.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^7",
    "vitepress": "1.6.4",
    "vitepress-plugin-llms": "1.13.2"
  },
  "dependencies": {
    "@mtcute/bun": "^0.30.3",
    "@mtcute/convert": "^0.30.3",
    "qrcode-terminal": "^0.12.0"
  },
  "overrides": {
    "vite": "6.4.3"
  }
}
